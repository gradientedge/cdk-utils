{
  "name": "cdk-utils-root",
  "description": "Utilities for AWS CDK, Azure and Cloudflare Pulumi provisioning",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22 <=24",
    "pnpm": ">=10"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gradientedge/cdk-utils.git"
  },
  "keywords": [
    "gradientedge",
    "aws",
    "azure",
    "cloudflare",
    "cdk",
    "aws-cdk",
    "pulumi",
    "iac",
    "typescript"
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/gradientedge/cdk-utils/issues"
  },
  "homepage": "https://github.com/gradientedge/cdk-utils#readme",
  "scripts": {
    "build": "pnpm -r build",
    "build:production": "pnpm -r build:production",
    "ci": "pnpm install --frozen-lockfile && pnpm build && pnpm validate && pnpm run docs",
    "docs": "rimraf api-docs && typedoc && cp -r img api-docs/img",
    "fix": "pnpm prettify && eslint --fix **/*.ts",
    "lint": "eslint **/*.ts --max-warnings=0 --no-warn-ignored",
    "prettier": "prettier --check \"**/*.{ts,json,md,yaml,yml}\"",
    "prettify": "prettier --write \"**/*.{ts,json,md,yaml,yml}\"",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "test:coverage": "pnpm -r test:coverage",
    "update": "pnpm update -r --latest -i",
    "validate": "pnpm prettier && pnpm lint && pnpm test",
    "prepare": "husky",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@changesets/changelog-github": "0.7.0",
    "@changesets/cli": "2.31.0",
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@eslint/config-array": "0.23.5",
    "@eslint/object-schema": "3.0.5",
    "@types/node": "25.9.1",
    "@typescript-eslint/eslint-plugin": "8.59.4",
    "@typescript-eslint/parser": "8.59.4",
    "@vitest/coverage-v8": "4.1.7",
    "aws-cdk": "2.1124.1",
    "dotenv": "17.4.2",
    "esbuild": "0.28.0",
    "eslint": "10.4.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jsdoc": "63.0.0",
    "husky": "9.1.7",
    "prettier": "3.8.3",
    "prettier-plugin-organize-imports": "4.3.0",
    "rimraf": "6.1.3",
    "rollup": "4.60.4",
    "ts-md5": "2.0.1",
    "ts-node": "10.9.2",
    "typedoc": "^0.28.19",
    "typedoc-plugin-merge-modules": "^7.0.0",
    "typedoc-plugin-mermaid": "^1.12.0",
    "typescript": "6.0.3",
    "vitest": "4.1.7",
    "yaml": "2.9.0"
  },
  "packageManager": "pnpm@11.5.0"
}
