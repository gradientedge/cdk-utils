{
  "name": "@gradientedge/cdk-utils",
  "version": "0.0.0",
  "description": "Utilities for AWS CDK provisioning",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "engines": {
    "node": ">=22 <=24",
    "pnpm": "=10"
  },
  "packageManager": "pnpm@10.32.1",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gradientedge/cdk-utils.git"
  },
  "release": {
    "branches": [
      "main"
    ]
  },
  "keywords": [
    "gradientedge",
    "cdk",
    "pulumi",
    "awscdk"
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/gradientedge/cdk-utils/issues"
  },
  "homepage": "https://github.com/gradientedge/cdk-utils#readme",
  "scripts": {
    "build": "rimraf dist/ && tsc && pnpm -r build",
    "build:production": "rimraf dist/ && tsc -p tsconfig.prd.json && pnpm -r build",
    "ci": "pnpm install --frozen-lockfile && pnpm build && pnpm validate && pnpm run docs",
    "cz": "cz",
    "docs": "rimraf api-docs && pnpm override:plugin:docs && jsdoc --pedantic -c jsdoc.json .",
    "fix": "pnpm prettify && eslint --fix **/*.ts",
    "lint": "pnpm prettify && eslint **/*.ts --cache --max-warnings=0 --no-warn-ignored",
    "override:plugin:docs": "cp theme/type-converter.js node_modules/better-docs/typescript",
    "prettier": "prettier --cache --check \"**/*.{ts,json,md}\"",
    "prettify": "prettier --cache --write \"**/*.{ts,json,md}\"",
    "test": "rimraf coverage && vitest run --coverage",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --reporter=verbose",
    "test:coverage:open": "vitest run --coverage && open coverage/index.html",
    "update:deps": "ncu -u --deep --reject react,react-dom",
    "validate": "pnpm prettier && pnpm lint && pnpm test",
    "prepare": "husky"
  },
  "dependencies": {
    "@aws-sdk/client-secrets-manager": "^3.1010.0",
    "@aws-sdk/credential-providers": "^3.1010.0",
    "@aws-sdk/types": "^3.973.6",
    "@pulumi/archive": "^0.3.7",
    "@pulumi/aws": "^7.23.0",
    "@pulumi/azure-native": "^3.15.0",
    "@pulumi/cloudflare": "^6.13.0",
    "@pulumi/command": "^1.2.1",
    "@pulumi/pulumi": "^3.226.0",
    "@pulumi/std": "^2.3.2",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.5.0",
    "app-root-path": "^3.1.0",
    "aws-cdk-lib": "^2.243.0",
    "constructs": "^10.5.1",
    "json5": "^2.2.3",
    "lodash": "^4.17.23",
    "moment": "^2.30.1",
    "nconf": "^0.13.0",
    "pluralize": "^8.0.0",
    "ts-node": "^10.9.2",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/eslint-parser": "^7.28.6",
    "@eslint/config-array": "^0.23.3",
    "@eslint/object-schema": "^3.0.3",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitest/coverage-v8": "^4.1.0",
    "aws-cdk": "^2.1111.0",
    "better-docs": "^2.7.3",
    "commitizen": "^4.3.1",
    "docdash": "^2.0.2",
    "dotenv": "^17.3.1",
    "esbuild": "^0.27.4",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsdoc": "^62.8.0",
    "husky": "^9.1.7",
    "jsdoc": "^4.0.5",
    "jsdoc-babel": "^0.5.0",
    "jsdoc-mermaid": "^1.0.0",
    "jsdoc-plugin-typescript": "^3.2.0",
    "jsdoc-to-markdown": "^9.1.3",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "rimraf": "^6.1.3",
    "rollup": "^4.59.0",
    "semantic-release": "^25.0.3",
    "taffydb": "^2.7.3",
    "ts-md5": "^2.0.1",
    "ts-node": "^10.9.2",
    "typescript": "5.9.3",
    "vitest": "^4.1.0",
    "yaml": "^2.8.2"
  },
  "optionalDependencies": {
    "prop-types": "^15.8.1",
    "react": "^17.0.0",
    "react-dom": "^17.0.0"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "workspaces": [
    "app/api-destined-function/*",
    "src/*"
  ]
}
