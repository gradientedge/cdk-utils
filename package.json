{
  "name": "cdk-utils-root",
  "description": "Utilities for AWS CDK, Azure and Cloudflare Pulumi provisioning",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22 <=24",
    "pnpm": "=10"
  },
  "packageManager": "pnpm@10.33.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gradientedge/cdk-utils.git"
  },
  "keywords": [
    "gradientedge",
    "cdk",
    "pulumi"
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/gradientedge/cdk-utils/issues"
  },
  "homepage": "https://github.com/gradientedge/cdk-utils#readme",
  "scripts": {
    "build": "pnpm -r build",
    "build:production": "pnpm -r build:production",
    "ci": "pnpm install --frozen-lockfile && pnpm build && pnpm validate && pnpm run docs",
    "cz": "cz",
    "docs": "rimraf api-docs && pnpm override:plugin:docs && jsdoc --pedantic -c jsdoc.json .",
    "fix": "pnpm prettify && eslint --fix **/*.ts",
    "lint": "pnpm prettify && eslint **/*.ts --cache --max-warnings=0 --no-warn-ignored",
    "override:plugin:docs": "cp theme/type-converter.js node_modules/better-docs/typescript",
    "prettier": "prettier --cache --check \"**/*.{ts,json,md}\"",
    "prettify": "prettier --cache --write \"**/*.{ts,json,md}\"",
    "test": "rimraf coverage && vitest run --coverage",
    "test:watch": "vitest",
    "test:coverage": "pnpm -r test:coverage",
    "update:deps": "ncu -u --deep --reject react,react-dom",
    "validate": "pnpm prettier && pnpm lint && pnpm test",
    "prepare": "husky",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@babel/core": "7.29.0",
    "@babel/eslint-parser": "7.28.6",
    "@changesets/changelog-github": "0.6.0",
    "@changesets/cli": "2.30.0",
    "@eslint/config-array": "0.23.3",
    "@eslint/object-schema": "3.0.3",
    "@types/node": "25.5.0",
    "@typescript-eslint/eslint-plugin": "8.58.0",
    "@typescript-eslint/parser": "8.58.0",
    "@vitest/coverage-v8": "4.1.2",
    "aws-cdk": "2.1116.0",
    "better-docs": "2.7.3",
    "commitizen": "4.3.1",
    "docdash": "2.0.2",
    "dotenv": "17.4.0",
    "esbuild": "0.27.5",
    "eslint": "10.1.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jsdoc": "62.9.0",
    "husky": "9.1.7",
    "jsdoc": "4.0.5",
    "jsdoc-babel": "0.5.0",
    "jsdoc-mermaid": "1.0.0",
    "jsdoc-plugin-typescript": "3.2.0",
    "jsdoc-to-markdown": "9.1.3",
    "prettier": "3.8.1",
    "prettier-plugin-organize-imports": "4.3.0",
    "rimraf": "6.1.3",
    "rollup": "4.60.1",
    "taffydb": "2.7.3",
    "ts-md5": "2.0.1",
    "ts-node": "10.9.2",
    "typescript": "6.0.2",
    "vitest": "4.1.2",
    "yaml": "2.8.3"
  },
  "optionalDependencies": {
    "prop-types": "15.8.1",
    "react": "17.0.2",
    "react-dom": "17.0.2"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "workspaces": [
    "packages/*",
    "app/api-destined-function/*"
  ]
}
