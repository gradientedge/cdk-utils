{
  "name": "@gradientedge/cdk-utils-aws",
  "version": "2.10.0",
  "description": "AWS CDK utilities for @gradientedge/cdk-utils",
  "type": "module",
  "main": "dist/src/index.js",
  "exports": {
    ".": {
      "import": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts"
    }
  },
  "files": [
    "dist/src/"
  ],
  "scripts": {
    "build": "tsc",
    "build:production": "tsc -p tsconfig.prd.json",
    "test": "vitest run --coverage",
    "lint": "eslint src/**/*.ts --cache --max-warnings=0 --no-warn-ignored"
  },
  "dependencies": {
    "@aws-sdk/client-secrets-manager": "3.1054.0",
    "@aws-sdk/credential-providers": "3.1054.0",
    "@aws-sdk/types": "3.973.9",
    "@gradientedge/cdk-utils-common": "workspace:*",
    "@types/lodash": "catalog:",
    "app-root-path": "catalog:",
    "aws-cdk-lib": "2.257.0",
    "lodash": "catalog:",
    "constructs": "10.6.0",
    "moment": "2.30.1",
    "uuid": "catalog:"
  },
  "keywords": [
    "gradientedge",
    "aws",
    "cdk",
    "aws-cdk",
    "iac",
    "typescript"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gradientedge/cdk-utils.git",
    "directory": "packages/aws"
  },
  "typedocOptions": {
    "gitRevision": "main",
    "sourceLinkTemplate": "https://github.com/gradientedge/cdk-utils/blob/main/{path}#L{line}"
  }
}
