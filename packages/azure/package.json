{
  "name": "@gradientedge/cdk-utils-azure",
  "version": "2.17.0",
  "description": "Azure Pulumi utilities for @gradientedge/cdk-utils",
  "type": "module",
  "main": "dist/src/index.js",
  "exports": {
    ".": {
      "import": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts"
    }
  },
  "files": [
    "dist/src/"
  ],
  "scripts": {
    "build": "tsc",
    "build:production": "tsc -p tsconfig.prd.json",
    "test": "vitest run --coverage",
    "lint": "eslint src/**/*.ts --cache --max-warnings=0 --no-warn-ignored"
  },
  "dependencies": {
    "@gradientedge/cdk-utils-common": "workspace:*",
    "@pulumi/archive": "0.3.7",
    "@pulumi/azure-native": "3.16.0",
    "@pulumi/azuread": "6.9.0",
    "@pulumi/pulumi": "3.230.0",
    "@types/lodash": "4.17.24",
    "app-root-path": "3.1.0",
    "lodash": "4.18.1",
    "yaml": "2.8.3"
  },
  "keywords": [
    "gradientedge",
    "azure",
    "pulumi",
    "iac",
    "typescript"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gradientedge/cdk-utils.git",
    "directory": "packages/azure"
  },
  "typedocOptions": {
    "gitRevision": "main",
    "sourceLinkTemplate": "https://github.com/gradientedge/cdk-utils/blob/main/{path}#L{line}"
  }
}
